{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "desktop:vite:dev": "vite --config vite.desktop.config.js --host 127.0.0.1 --port 1420",
        "desktop:vite:build": "vite build --config vite.desktop.config.js",
        "desktop:dev": "tauri dev",
        "desktop:build": "tauri build && npm run desktop:adhoc-sign",
        "desktop:adhoc-sign": "node scripts/sign-macos-bundle.mjs",
        "desktop:media:prepare": "node scripts/prepare-media-sidecars.mjs",
        "desktop:media:build-lgpl": "node scripts/build-ffmpeg-lgpl-sidecars.mjs",
        "desktop:media:check": "node scripts/prepare-media-sidecars.mjs --check",
        "desktop:clean": "node scripts/clean-desktop-artifacts.mjs",
        "desktop:dmg:create": "node scripts/create-macos-dmg.mjs",
        "desktop:updater:keys": "node scripts/prepare-updater-keys.mjs",
        "desktop:updater:prepare": "node scripts/prepare-updater-config.mjs",
        "desktop:updater:check": "node scripts/prepare-updater-config.mjs --check --require-private-key",
        "desktop:updater:latest": "node scripts/generate-tauri-latest-json.mjs",
        "desktop:github:release-secrets:plan": "node scripts/configure-github-release-secrets.mjs",
        "desktop:release:preflight": "node scripts/desktop-release-preflight.mjs",
        "desktop:release:preflight:strict": "node scripts/desktop-release-preflight.mjs --strict",
        "desktop:smoke:launch": "node scripts/smoke-launch-macos.mjs",
        "desktop:build:with-media": "npm run desktop:media:check && tauri build --config src-tauri/tauri.media-sidecars.conf.json && npm run desktop:adhoc-sign",
        "desktop:build:with-updater": "node scripts/build-desktop-release.mjs --updater",
        "desktop:build:with-media-and-updater": "node scripts/build-desktop-release.mjs --media --updater",
        "desktop:fmt:check": "cd src-tauri && cargo fmt --check",
        "desktop:test": "cd src-tauri && cargo test",
        "desktop:release:check": "npm run desktop:vite:build && npm run desktop:fmt:check && npm run desktop:test",
        "desktop:release:build": "npm run desktop:release:check && npm run desktop:build",
        "desktop:release:build:with-media": "npm run desktop:release:check && npm run desktop:build:with-media",
        "desktop:release:build:with-updater": "npm run desktop:release:check && npm run desktop:build:with-updater",
        "desktop:release:build:with-media-and-updater": "npm run desktop:release:check && npm run desktop:build:with-media-and-updater",
        "desktop:release:build:signed": "npm run desktop:release:check && node scripts/build-macos-release.mjs --dmg --bundles app",
        "desktop:release:build:signed:with-media": "npm run desktop:release:check && node scripts/build-macos-release.mjs --media --dmg --bundles app",
        "desktop:release:build:signed:with-media-and-updater": "npm run desktop:release:check && node scripts/build-macos-release.mjs --media --updater --dmg --bundles app",
        "desktop:macos:notarize": "node scripts/notarize-macos-app.mjs",
        "desktop:macos:notarize:wait": "node scripts/notarize-macos-app.mjs --submission-id",
        "desktop:macos:notarize:status": "node scripts/notarize-macos-app.mjs --status --submission-id"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.1.3",
        "@tauri-apps/cli": "^2.11.3",
        "@vitejs/plugin-vue": "^5.2.3",
        "axios": "^1.7.7",
        "laravel-vite-plugin": "^1.0.5",
        "lodash": "^4.17.19",
        "os": "^0.1.2",
        "path": "^0.12.7",
        "tailwindcss": "^4.1.3",
        "unplugin-vue-define-options": "^1.3.7",
        "vite": "^5.4.9",
        "vue": "^3.5.13"
    },
    "dependencies": {
        "@inertiajs/vue3": "^1.0.2",
        "@jaames/iro": "^5.5.2",
        "@tauri-apps/api": "^2.11.1",
        "@tauri-apps/plugin-dialog": "^2.7.1",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@tauri-apps/plugin-opener": "^2.5.4",
        "@tauri-apps/plugin-updater": "^2.10.1",
        "@tiptap/core": "^2.7.2",
        "@tiptap/extension-document": "^2.7.2",
        "@tiptap/extension-history": "^2.7.2",
        "@tiptap/extension-link": "^2.7.2",
        "@tiptap/extension-placeholder": "^2.7.2",
        "@tiptap/extension-text": "^2.7.2",
        "@tiptap/extension-typography": "^2.7.2",
        "@tiptap/pm": "^2.7.2",
        "@tiptap/vue-3": "^2.7.2",
        "chart.js": "^4.1.2",
        "chartjs-plugin-zoom": "^2.0.0",
        "core-js": "^3.29.0",
        "date-fns": "^2.29.1",
        "date-fns-tz": "^1.3.7",
        "emoji-mart-vue-fast": "^11.1.1",
        "floating-vue": "^5.2.2",
        "mitt": "^3.0.1",
        "nanoid": "^5.0.7",
        "nprogress": "^0.2.0",
        "twemoji-parser": "^14.0.0",
        "twitter-text": "^3.1.0",
        "vue-flatpickr-component": "^9.0.6",
        "vuedraggable": "^4.1.0",
        "ziggy-js": "^2.5.2"
    }
}
