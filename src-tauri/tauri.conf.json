{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dust Wave Social",
  "version": "0.1.0",
  "identifier": "com.dustwave.social",
  "build": {
    "beforeDevCommand": "npm run desktop:vite:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run desktop:vite:build",
    "frontendDist": "../resources/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dust Wave Social",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/media/**"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: https:; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "copyright": "Copyright Dust Wave",
    "category": "Productivity"
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
